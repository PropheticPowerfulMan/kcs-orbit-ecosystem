generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ACCOUNTANT
  PARENT
}

enum PaymentMethod {
  CASH
  AIRTEL_MONEY
  MPESA
  ORANGE_MONEY
}

enum PaymentStatus {
  COMPLETED
  PENDING
  FAILED
}

enum NotificationType {
  CONFIRMATION
  REMINDER
  LATE_ALERT
}

enum NotificationChannel {
  SMS
  EMAIL
}

model School {
  id          String    @id @default(cuid())
  name        String
  createdAt   DateTime  @default(now())
  users       User[]
  parents     Parent[]
  students    Student[]
  classes     Class[]
  payments    Payment[]
  receipts    Receipt[]
  insights    AIInsight[]
  riskScores  RiskScore[]
  audits      AuditLog[]
}

model User {
  id           String   @id @default(cuid())
  schoolId     String
  fullName     String
  email        String   @unique
  accessCode   String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent       Parent?
  createdPayments Payment[] @relation("CreatedPayments")
  auditLogs    AuditLog[]
}

model Parent {
  id                String   @id @default(cuid())
  schoolId          String
  userId            String?  @unique
  fullName          String
  phone             String
  email             String
  photoUrl          String?
  preferredLanguage String   @default("fr")
  createdAt         DateTime @default(now())
  school            School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user              User?    @relation(fields: [userId], references: [id])
  students          Student[]
  payments          Payment[]
  notifications     NotificationLog[]
  riskScores        RiskScore[]
}

model Class {
  id        String    @id @default(cuid())
  schoolId  String
  name      String
  level     String
  createdAt DateTime  @default(now())
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students  Student[]

  @@unique([schoolId, name])
}

model Student {
  id         String    @id @default(cuid())
  schoolId   String
  parentId   String
  classId    String
  externalStudentId String?
  fullName   String
  annualFee  Float
  createdAt  DateTime  @default(now())
  school     School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent     Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  class      Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  payments   Payment[]

  @@unique([schoolId, externalStudentId])
}

model Payment {
  id                String        @id @default(cuid())
  schoolId          String
  transactionNumber String        @unique
  parentId          String
  reason            String
  amount            Float
  amountInWords     String
  method            PaymentMethod
  status            PaymentStatus
  createdById       String
  createdAt         DateTime      @default(now())
  school            School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent            Parent        @relation(fields: [parentId], references: [id], onDelete: Cascade)
  createdBy         User          @relation("CreatedPayments", fields: [createdById], references: [id])
  students          Student[]
  receipt           Receipt?
}

model Receipt {
  id            String   @id @default(cuid())
  schoolId      String
  paymentId     String   @unique
  receiptNumber String   @unique
  pdfBase64     String
  pngBase64     String
  createdAt     DateTime @default(now())
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  payment       Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model NotificationLog {
  id        String              @id @default(cuid())
  schoolId  String
  parentId  String
  type      NotificationType
  language  String
  channel   NotificationChannel
  content   String
  status    String
  createdAt DateTime            @default(now())
  parent    Parent              @relation(fields: [parentId], references: [id], onDelete: Cascade)
}

model AIInsight {
  id          String   @id @default(cuid())
  schoolId    String
  title       String
  description String
  priority    String
  createdAt   DateTime @default(now())
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model RiskScore {
  id         String   @id @default(cuid())
  schoolId   String
  parentId   String
  score      Float
  category   String
  modelVer   String
  createdAt  DateTime @default(now())
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent     Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  schoolId  String
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
