generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
  TEACHER
  PARENT
  STUDENT
}

enum AppSlug {
  KCS_NEXUS
  EDUPAY
  EDUSYNCAI
  SAVANEX
}

enum ConnectionStatus {
  ACTIVE
  INACTIVE
}

enum AccessStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum LoginMode {
  LOCAL_CREDENTIALS
  EXTERNAL_AUTH
  MANAGED_BY_APP
}

enum SyncDirection {
  INBOUND
  OUTBOUND
}

enum SyncStatus {
  PENDING
  PROCESSED
  FAILED
}

model Organization {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  isActive       Boolean         @default(true)
  users          User[]
  sharedProfiles SharedProfile[]
  appAccesses    AppAccess[]
  parents        Parent[]
  teachers       Teacher[]
  classes        Class[]
  students       Student[]
  payments       Payment[]
  grades         Grade[]
  attendances    Attendance[]
  announcements  Announcement[]
  externalLinks  ExternalLink[]
  appConnections AppConnection[]
  syncEvents     SyncEvent[]
  auditLogs      AuditLog[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  passwordHash String
  role         Role
  organizationId String?
  organization Organization? @relation(fields: [organizationId], references: [id])
  auditLogs     AuditLog[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SharedProfile {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  fullName       String
  email          String?
  phone          String?
  role           Role?
  appAccesses    AppAccess[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
  @@index([organizationId, email])
}

model AppAccess {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  profileId      String
  profile        SharedProfile @relation(fields: [profileId], references: [id])
  appSlug        AppSlug
  accessRole     String
  loginMode      LoginMode     @default(MANAGED_BY_APP)
  status         AccessStatus  @default(ACTIVE)
  localUsername  String?
  externalUserId String?
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([organizationId, appSlug, profileId])
  @@index([organizationId, appSlug])
  @@index([organizationId, externalUserId])
}

model AppConnection {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  appSlug        AppSlug
  baseUrl        String
  status         ConnectionStatus @default(ACTIVE)
  lastSyncedAt   DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organizationId, appSlug])
}

model ExternalLink {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  appSlug        AppSlug
  entityType     String
  nexusEntityId  String
  externalId     String
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, appSlug, entityType, externalId])
}

model SyncEvent {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  appSlug        AppSlug
  eventType      String
  entityType     String
  entityId       String
  direction      SyncDirection
  status         SyncStatus    @default(PENDING)
  payload        Json?
  processedAt    DateTime?
  errorMessage   String?
  createdAt      DateTime      @default(now())
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime     @default(now())
}

model Parent {
  id             String        @id @default(cuid())
  fullName       String
  phone          String?
  email          String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  students       Student[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
}

model Teacher {
  id             String        @id @default(cuid())
  fullName       String
  phone          String?
  email          String?
  subject        String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  classes        Class[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
}

model Class {
  id             String        @id @default(cuid())
  name           String
  gradeLevel     String?
  teacherId      String?
  organizationId String?
  teacher        Teacher?      @relation(fields: [teacherId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  students       Student[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
}

model Student {
  id             String        @id @default(cuid())
  firstName      String
  lastName       String
  gender         String
  classId        String?
  parentId       String?
  organizationId String?
  class          Class?        @relation(fields: [classId], references: [id])
  parent         Parent?       @relation(fields: [parentId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  payments       Payment[]
  grades         Grade[]
  attendances    Attendance[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
}

model Payment {
  id             String        @id @default(cuid())
  studentId      String
  organizationId String?
  student        Student       @relation(fields: [studentId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  amount         Float
  motif          String
  method         String?
  reference      String?
  createdAt      DateTime      @default(now())

  @@index([organizationId])
}

model Grade {
  id             String        @id @default(cuid())
  studentId      String
  organizationId String?
  student        Student       @relation(fields: [studentId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  subject        String
  score          Float
  maxScore       Float
  term           String?
  createdAt      DateTime      @default(now())

  @@index([organizationId])
}

model Attendance {
  id             String        @id @default(cuid())
  studentId      String
  organizationId String?
  student        Student       @relation(fields: [studentId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  date           DateTime
  status         String
  createdAt      DateTime      @default(now())

  @@index([organizationId])
}

model Announcement {
  id             String        @id @default(cuid())
  title          String
  message        String
  audience       String
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())

  @@index([organizationId])
}
